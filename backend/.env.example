INFISTAR_API_KEY=
INFISTAR_BASE_URL=https://infistar.ai/v1
INFISTAR_MODEL=
PORT=3000
NODE_ENV=development

# 线上填写 Chrome Web Store 分配的正式扩展来源。
# 多个来源用英文逗号分隔。本地开发可留空。
ALLOWED_EXTENSION_ORIGINS=

# 部署在一层可信反向代理（如常见云平台）后面时设为 1。
# 直接暴露 Node 服务或本地开发时保持 0。
TRUST_PROXY=0

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
UPSTREAM_TIMEOUT_MS=45000
